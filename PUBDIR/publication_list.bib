@article{silva2017,
 author = {A. Silva and M. Silva and P. Sudalagunta and A. Distler and T. Jacobson and A. Collins and T. Nguyen and J. Song and D.T. Chen and Lu Chen and C. Cubitt and R. Baz and L. Perez and D. Rebatchouk and W. Dalton and J.M. Greene and R. Gatenby and R. Gillies and E.D. Sontag and M. Meads and K. Shain},
