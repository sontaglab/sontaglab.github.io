@ARTICLE{two-layer,
 author = {E.D. Sontag},
 title = {Feedback stabilization using two-hidden-layer nets},
keywords={machine learning, artificial intelligence, neural networks, feedback stabilization},
 journal= {IEEE Trans.\ Neural Networks},
 volume = {3},
 year = {1992},
 pages = {981--990},
pdf = {../../FTPDIR/1982_sontag_feedback_stabilization_two_hidden_layers_ieee_tnn.pdf},
abstract = {
This paper compares the representational capabilities of
one hidden layer and two hidden layer nets
consisting of feedforward interconnections of linear threshold units.
It is remarked that for certain problems two hidden layers are required,
contrary to
what might be in principle expected from the known approximation theorems.
The differences are not based on numerical accuracy or number of units needed,
nor on capabilities for feature extraction, but rather on a much more basic
classification into "direct" and "inverse" problems.  The former
correspond to the approximation of continuous functions, while the latter are
concerned with approximating one-sided inverses of continuous functions
- and are often encountered in the context of inverse kinematics
determination or in control questions.
A general result is given showing that nonlinear control systems can be
stabilized using two hidden layers, but not in general using just one.
},
}

