@article{arxiv:futileequilibria,
year = {2008},
volume = {57},
pages = {29-52},
author = {L. Wang and E.D. Sontag},
title = {On the number of steady states in a multiple futile cycle},
pdf = {../../FTPDIR/liming_wang_sontag_futile_cycles_JMB08.pdf},
keywords = {singular perturbations, futile cycles, MAPK cascades, systems biology, reaction networks, multistability},
abstract={This note studies the number of positive steady states in biomolecular reactions consisting of activation/deactivation futile cycles, such as those arising from phosphorylations and dephosphorylations at each level of a MAPK cascade.  It is shown that:
(1) for some parameter ranges, there are at least n+1 (if n is even) or n
(if n is odd) steady states;
(2) there never are more than 2n-1 steady states (so, for n=2, there are no more than 3 steady states);
(3) for parameters near the standard Michaelis-Menten quasi-steady
state conditions, there are at most n+1 steady states; and
(4) for parameters far from the standard Michaelis-Menten quasi-steady
state conditions, there is
at most one steady state.},
journal = {Journal of Mathematical Biology},
}

