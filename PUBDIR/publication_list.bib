@INPROCEEDINGS{11cdc_shoval_alon_sontag,
 author = {O. Shoval and U. Alon and E.D. Sontag},
 title = {Input symmetry invariance, and applications to biological systems},
 pages = {TuA02.5},
  keywords={adaptation, biological adaptation, perfect adaptation, adaptation,feedforward loops,integral feedback,scale invariance,systems biology,transient behavior,symmetries,fcd,fold-change detection,jump Markov processes},
 year = {2011},
