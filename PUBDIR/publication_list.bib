@INPROCEEDINGS{translation-inv-med06,
 year = 2006,
 publisher = {IEEE},
 pages={1-6},
 keywords={systems biology, reaction networks, nonlinear stability, dynamical systems, monotone systems},
 author = {D. Angeli and E.D. Sontag},
 doi = {10.1109/MED.2006.3287822B2B2B2B2B2B},
 title = {A note on monotone systems with positive translation invariance},
 booktitle = {Control and Automation, 2006. MED '06. 14th Mediterranean Conference on, 28-30 June 2006},
 note = {available from ieeexplore.ieee.org},
pdf = {../../FTPDIR/angeli_translation_invariance_med06.pdf},
abstract = {
Strongly monotone systems of ordinary differential equations
which have a certain translation-invariance property are shown to
have the property that all projected solutions converge to a unique
equilibrium. 
This result may be seen as a dual of a well-known theorem of Mierczynski for
systems that satisfy a conservation law.
As an application, it is shown that enzymatic futile cycles have a
global convergence property.
},
}

