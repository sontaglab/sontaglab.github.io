      YEAR = {1989},
    NUMBER = {1},
     PAGES = {91--106},
      ISSN = {0891-2513},
pdf = {../../FTPDIR/complex_systems.pdf},
abstract = {
We give an example of a neural net without hidden
layers and with a sigmoid transfer function, together with a
training set of binary vectors, for which the sum of the
squared errors, regarded as a function of the weights, has a local
minimum which is not a global minimum.
The example consists of a set of 125 training instances, with four weights
and a threshold to be learnt.  We do not know if substantially smaller binary
examples exist.
},
}

@article {MR1014237,
    AUTHOR = {Sontag, E.D.},
  keywords = {control-Lyapunov functions,stabilization, real-analytic functions},
 TITLE = {A ``universal'' construction of {A}rtstein's theorem on
              nonlinear stabilization},
   JOURNAL = {Systems Control Lett.},
    VOLUME = {13},
      YEAR = {1989},
    NUMBER = {2},
     PAGES = {117--123},
      ISSN = {0167-6911},
 publisher = {Elsevier Science Publishers B. V.},
 address = {Amsterdam, The Netherlands, The Netherlands},
pdf = {../../FTPDIR/art-sycon8903.pdf},
abstract = {
This note presents an explicit proof of the theorem - due to Artstein - which
states that the existence of a smooth control-Lyapunov function implies smooth
stabilizability.  Moreover, the result is extended to the real-analytic and
rational cases as well.  The proof uses a "universal" formula given by an
algebraic function of Lie derivatives; this formula originates in the solution
of a simple Riccati equation.
},
}

@article {MR1029482,
    AUTHOR = {Arapostathis, A. and Jakubczyk, B. and Lee, H.-G. and Marcus,
              S. I. and Sontag, E.D.},
 TITLE = {The effect of sampling on linear equivalence and feedback
              linearization},
   JOURNAL = {Systems Control Lett.},
    VOLUME = {13},
      YEAR = {1989},
    NUMBER = {5},
     PAGES = {373--381},
