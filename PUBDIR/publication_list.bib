@article {MR1437210,
keywords={machine learning, artificial intelligence, neural networks, optimization, approximation theory},
    AUTHOR = {Donahue, M. J. and Gurvits, L. and Darken, C. and Sontag, E.D.},
 TITLE = {Rates of convex approximation in non-{H}ilbert spaces},
   JOURNAL = {Constr. Approx.},
    VOLUME = {13},
      YEAR = {1997},
    NUMBER = {2},
     PAGES = {187--220},
      ISSN = {0176-4276},
pdf = {../../FTPDIR/ddgs.pdf},
abstract = {
This paper deals with sparse approximations by means of convex
combinations of elements from a predetermined "basis" subset S of
a function space.  Specifically, the focus is on the rate at
which the lowest achievable error can be reduced as larger subsets of
S are allowed when constructing an approximant.  The new results
extend those given for Hilbert spaces by Jones and Barron, including
in particular a computationally attractive incremental approximation
scheme.  Bounds are derived for broad classes of Banach spaces.
The techniques used borrow from results regarding moduli of smoothness in
functional analysis as well as from the theory of stochastic processes on
function spaces.
},
}

@article {clss97,
    AUTHOR = {Clarke, F. H. and Ledyaev, Y.S. and Sontag, E.D.
