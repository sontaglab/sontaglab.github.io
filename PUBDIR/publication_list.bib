@INPROCEEDINGS{91ecc,
 year = 1991,
 author = {F. Albertini and E.D. Sontag},
 title = {Some connections between chaotic dynamical systems and control systems},
 booktitle = {{\it Proc.\ European Control Conf.\ \/}, Vol 1, Grenoble, July 1991},
 pages = {58--163},
pdf = {../../FTPDIR/91ecc.pdf},
keywords = {chaotic systems, controllability},
abstract = {
This paper shows how to extend recent results of Colonius and Kliemann,
regarding connections between chaos and controllability, from continuous to
discrete time.  The extension is nontrivial because the results all rely on
basic properties of the accessibility Lie algebra which fail to hold in
discrete time. Thus, this paper first develops further results in nonlinear
accessibility, and then shows how a theorem can be proved, which while
analogous to the one given in the work by Colonius and Klieman, also exhibits
some important differences. A counterexample is used to show that the theorem
given in continuous time cannot be generalized in a straightforward manner.
},
}

