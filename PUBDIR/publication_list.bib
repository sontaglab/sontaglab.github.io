 note = {(Paper WE-E A2, CD-ROM file ECC958.pdf, 6 pages)},
pdf = {../../FTPDIR/97ecc-ios.pdf},
keywords = { input to state stability },
abstract = {
This paper deals with a notion of "input to output stability (IOS)",
which formalizes the idea that outputs depend in an "aymptotically stable"
manner on inputs, while internal signals remain bounded.
When the output equals the complete state, one recovers the property
of input to state stability (ISS).
When there are no inputs, one has a generalization of the classical concept of
partial stability.
The main results provide Lyapunov-function characterizations of IOS.
},
}

