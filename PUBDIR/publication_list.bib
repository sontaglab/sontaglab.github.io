@article {arcak_angeli_sontag_cascades_SICOPT02,
    AUTHOR = {Arcak, M. and Angeli, D. and Sontag, E.D.},
  keywords={input to state stability, integral input to state stability, iISS, ISS},
 TITLE = {A unifying integral {ISS} framework for stability of nonlinear
              cascades},
   JOURNAL = {SIAM J. Control Optim.},
    VOLUME = {40},
      YEAR = {2002},
    NUMBER = {6},
     PAGES = {1888--1904},
      ISSN = {0363-0129},
