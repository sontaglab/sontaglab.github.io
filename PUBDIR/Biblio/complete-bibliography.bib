@ARTICLE{angeli_sontag_wang_iISS_TAC00,
   AUTHOR       = {D. Angeli and E.D. Sontag and Y. Wang},
   JOURNAL      = {IEEE Trans. Automat. Control},
   TITLE        = {A characterization of integral input-to-state stability},
   YEAR         = {2000},
