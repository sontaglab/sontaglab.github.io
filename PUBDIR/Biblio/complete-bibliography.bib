   TITLE        = {From linear to nonlinear: some complexity comparisons},
   YEAR         = {1995},
   OPTADDRESS   = {},
   OPTCROSSREF  = {},
   OPTEDITOR    = {},
   OPTMONTH     = {},
   OPTNOTE      = {},
   OPTNUMBER    = {},
